# 订阅转换服务 Caddy 配置
# 实际部署位置: /etc/caddy/Caddyfile（与其他站点合并）
# 将 <your-domain> 替换为实际域名

<your-domain> {
    # 规则文件静态服务
    handle /config.ini {
        root * /root/subconverter/web
        file_server
    }
    handle /rules/* {
        root * /root/subconverter/web
        file_server
    }

    # 旧 subconverter API（兼容现有订阅链接）
    handle /sub* {
        reverse_proxy localhost:3000
    }

    # sub-store 前端 + 新 API
    reverse_proxy localhost:3002
}
