# 订阅转换服务 Caddy 配置
# 实际部署位置: /etc/caddy/Caddyfile（与其他站点合并）
# 将 <your-domain> 替换为实际域名

<your-domain> {
    # 订阅转换接口
    handle /convert {
        reverse_proxy localhost:3003
    }
    # sub-store 管理 API（内部使用）
    handle /sub-store-api/* {
        reverse_proxy localhost:3002
    }
    # 前端页面 + 规则文件
    handle {
        root * /root/subconverter/web
        file_server
    }
}
