# 订阅转换服务 Caddy 配置
# 实际部署位置: /etc/caddy/Caddyfile（与其他站点合并）
# 将 <your-domain> 替换为实际域名

<your-domain> {
    # 规则文件静态服务（供 config.ini 引用）
    handle /config.ini {
        root * /root/subconverter/web
        file_server
    }
    handle /rules/* {
        root * /root/subconverter/web
        file_server
    }

    # sub-store（前端 + API，含 /sub-store-api/ 路径）
    reverse_proxy localhost:3002
}
